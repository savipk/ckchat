# Ensure shell scripts keep LF endings (critical for Linux containers / DevPod)
*.sh text eol=lf
mvnw text eol=lf

# Windows batch files keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Java sources
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.json text eol=lf
