<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">
    <activeProfiles>
        <activeProfile>nexus</activeProfile>
    </activeProfiles>
    <mirrors>
        <mirror>
            <id>nexus</id>
            <mirrorOf>!ubs-snapshot,!dvp-release-v2,!dvp-release-v3,!ubs-release,!ubs-public,!ubs-maven-mirror,!confluent,!proxy-lib-java-maven-oss-mavencentral,*</mirrorOf>
            <name>Public - Maven</name>
            <url>https://it4it-nexus-tp-repo.swissbank.com/repository/public-maven/</url>
        </mirror>
    </mirrors>
    <profiles>
        <profile>
            <id>nexus</id>
            <pluginRepositories>
                <pluginRepository>
                    <id>ubs-maven-mirror</id>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                    <url>https://it4it-nexus-tp-repo.swissbank.com/repository/proxy-lib-java-maven-oss-mavencentral/</url>
                </pluginRepository>
            </pluginRepositories>
            <properties>
                <altReleaseDeploymentRepository>nexus-write::https://nexus-write.artifactmgmt.ubs.net/repository/deploy-shared-065-release/</altReleaseDeploymentRepository>
                <altSnapshotDeploymentRepository>nexus-write::https://nexus-write.artifactmgmt.ubs.net/repository/deploy-shared-065-snapshot/</altSnapshotDeploymentRepository>
            </properties>
            <repositories>
                <repository>
                    <id>central</id>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                    <url>https://it4it-nexus-tp-repo.swissbank.com/repository/public-maven/</url>
                </repository>
                <repository>
                    <id>ubs-public</id>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                    <url>https://nexus-write.artifactmgmt.ubs.net/repository/public/</url>
                </repository>
                <repository>
                    <id>ubs-release</id>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                    <url>https://nexus-write.artifactmgmt.ubs.net/repository/deploy-shared-065-release/</url>
                </repository>
                <repository>
                    <id>dvp-release-v2</id>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                    <url>https://nexus-write.ldn.swissbank.com/nexus/content/repositories/deploy-shared-034-release/</url>
                </repository>
                <repository>
                    <id>dvp-release-v3</id>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                    <url>https://nexus-write.artifactmgmt.ubs.net/repository/deploy-shared-034-release/</url>
                </repository>
                <repository>
                    <id>ubs-snapshot</id>
                    <releases>
                        <enabled>false</enabled>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                    <url>https://nexus-write.artifactmgmt.ubs.net/repository/deploy-shared-065-snapshot/</url>
                </repository>
                <repository>
                    <id>confluent</id>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                    <url>https://it4it-nexus-tp-repo.swissbank.com/repository/proxy-maven-oss-confluent-io/</url>
                </repository>
                <repository>
                    <id>proxy-lib-java-maven-oss-mavencentral</id>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                    <url>https://it4it-nexus-tp-repo.swissbank.com/repository/proxy-lib-java-maven-oss-mavencentral/</url>
                </repository>
            </repositories>
        </profile>
    </profiles>
    <servers>
        <server>
            <id>nexus-write</id>
            <password>${NEXUS_PASSWORD}</password>
            <username>SSO_682</username>
        </server>
    </servers>
</settings>
